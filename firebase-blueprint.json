{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Digital product or service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["id", "name", "type"]
    },
    "Category": {
      "title": "Category",
      "description": "Product variation or plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "product_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "popular": { "type": "boolean" }
      },
      "required": ["id", "product_id", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "product_name": { "type": "string" },
        "category_name": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["Menunggu", "Proses", "Selesai", "Dibatalkan"] },
        "date": { "type": "string", "format": "date-time" },
        "target_id": { "type": "string" },
        "zone_id": { "type": "string" }
      },
      "required": ["id", "user_id", "product_name", "category_name", "price", "date"]
    },
    "SocialProof": {
      "title": "SocialProof",
      "description": "Manual social proof notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "product_name": { "type": "string" },
        "category_name": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "name", "location", "product_name", "category_name", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories/plans"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "social_proofs/{proofId}": {
      "schema": "SocialProof",
      "description": "Manual social proofs"
    }
  }
}
